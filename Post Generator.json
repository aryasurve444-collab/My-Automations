    {
      "parameters": {
        "jsCode": "// n8n Function Node\n// Input: $json.text contains raw JSON-like text\n\nconst text = $json.text;\n\n// Regex to match all URL/caption pairs\n// This regex matches \"url\":\"...\" and \"rewritten_caption\":\"...\" safely\nconst itemRegex = /{\\s*\"url\"\\s*:\\s*\"([^\"]+)\"\\s*,\\s*\"rewritten_caption\"\\s*:\\s*\"([^\"]*)\"\\s*}/g;\n\nlet items = [];\nlet match;\n\n// Loop through all matches and push to items array\nwhile ((match = itemRegex.exec(text)) !== null) {\n    items.push({\n        json: {\n            url: match[1],\n            rewritten_caption: match[2]\n        }\n    });\n}\n\n// Return items array\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2672,
        -256
      ],
      "id": "12350595-f1d3-4f62-8c20-cde5ada03a65",
      "name": "Format"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.text;\nconst classified = JSON.parse(raw);\nconst posts = $node[\"Format Posts\"].json.posts;\n\nreturn classified.map(item => {\n  const cleanUrl = item.url.replace(/\\/$/, '');\n  const original = posts.find(p => p.url.replace(/\\/$/, '') === cleanUrl);\n  \n  if (!original) return { json: { url: item.url, classification: item.classification } };\n  \n  return {\n    json: {\n      caption: original.caption,\n      likesCount: original.likesCount,\n      commentsCount: original.commentsCount,\n      url: original.url,\n      timestamp: original.timestamp,\n      classification: item.classification\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1424,
        -256
      ],
      "id": "116f9f4c-058f-4e30-93de-fa7b780095b6",
      "name": "Split "
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst posts = items.map(item => ({\n  caption: item.json.caption,\n  url: item.json.url,\n  timestamp: item.json.timestamp,\n  likesCount: item.json.likesCount,\n  commentsCount: item.json.commentsCount\n}));\nreturn [{ json: { posts } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        -256
      ],
      "id": "7bbf947b-49ce-47df-9e24-feb38606da20",
      "name": "Format Posts"
    },
    {
      "parameters": {
        "jsCode": "const posts = $input.first().json.data;\n\nconst text = posts.map((p, i) => `Post ${i+1}:\n\nCaption: ${p.caption}\n\nLikes: ${p.likesCount}\n\nComments: ${p.commentsCount}\n\nURL: ${p.url}\n\nTimestamp: ${p.timestamp}`).join('\\n\\n---\\n\\n');\n\nreturn [{ json: { text } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
